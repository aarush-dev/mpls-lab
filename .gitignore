# Third-party reuse repos (cloned reference labs, not our source)
refs/

# Generated lab output (reproduce with: python3 generator/generate.py)
# Also contains WireGuard private keys — keep out of git.
topology/

# WireGuard keypair cache (secrets)
generator/.wg-keys.json

# Generated fault label timelines (runtime output; schema documented in faults/README.md)
faults/labels/

# Generated datasets (Parquet exports — reproduce via dataapi/export.py / synthetic/generate.py)
dataapi/datasets/
synthetic/output/

# Air-gap image bundles (large; produced by airgap/pull-and-save.sh)
airgap/images/

# Python / tooling cruft
__pycache__/
*.pyc
*.log

# Windows WSL artifacts
*:Zone.Identifier

# Claude Code skills (installed via uipro — reinstall with: uipro init --ai claude)
.claude/skills/
