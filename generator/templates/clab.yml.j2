name: {{ lab_name }}

# Generated by generator/generate.py from topology-spec.yaml — do not edit by hand.
mgmt:
  network: clab
  ipv4-subnet: 172.20.20.0/24
  # ponytail: host has no ip6tables nat chain (WSL2); disable IPv6 mgmt so docker
  # network creation doesn't fail on ip6tables.
  ipv6-subnet: ""
topology:
  defaults:
    kind: linux
  nodes:
{% for n in frr_nodes %}
    {{ n.name }}:
      kind: linux
      image: {{ frr_image }}
      image-pull-policy: Never
      mgmt-ipv4: {{ n.mgmt_ip }}
      binds:
        - configs/{{ n.name }}/frr.conf:/etc/frr/frr.conf
        - configs/{{ n.name }}/daemons:/etc/frr/daemons
        - configs/{{ n.name }}/snmpd.conf:/etc/snmp/snmpd.conf
        - configs/{{ n.name }}/vtysh.conf:/etc/frr/vtysh.conf
{% if n.role in ('P', 'PE') %}        - configs/{{ n.name }}/90-mpls.conf:/etc/sysctl.d/90-mpls.conf
{% endif %}{% if n.role == 'CE' %}        - configs/{{ n.name }}/qos.sh:/qos.sh
{% if n.has_wg %}        - configs/{{ n.name }}/wg0.conf:/etc/wireguard/wg0.conf
{% endif %}{% endif %}{% if n.exec %}      exec:
{% for e in n.exec %}        - {{ e }}
{% endfor %}{% endif %}
{% endfor %}
{% for h in host_nodes %}
    {{ h.name }}:
      kind: linux
      image: {{ host_image }}
      image-pull-policy: Never
      mgmt-ipv4: {{ h.mgmt_ip }}
      exec:
        - ip addr replace {{ h.addr }}/24 dev eth1
        - ip route replace default via {{ h.gw }}
{% endfor %}
  links:
{% for l in links %}
    - endpoints: ["{{ l.a }}", "{{ l.b }}"]
{% endfor %}
